# ==========================================
# AWS Credentials & Connection
# ==========================================
# AWS Access Key & Secret are required for the Radiko worker to read/delete 
# messages from its dedicated SQS queue. Provisioned via Terraform.
AWS_ACCESS_KEY_ID=your_radiko_worker_access_key
AWS_SECRET_ACCESS_KEY=your_radiko_worker_secret_key
# The AWS region where your SQS queues and SNS topics reside (default: ap-northeast-1)
AWS_REGION=ap-northeast-1

# The absolute URL of the Radiko SQS queue created by Terraform
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/media-downloader-radiko

# ==========================================
# Storage & Ownership
# ==========================================
# Google Drive Folder ID (Extracted from the URL of your Google Drive folder)
# If provided, the final merged audio will be uploaded to Drive and deleted locally.
# If left blank, the file will be preserved locally inside your DOWNLOAD_DIR.
GDRIVE_FOLDER_ID=1ABCDEFG_Your_Folder_ID_Here

# Host directory mapping for local storage. 
# Set this to a specific folder path on your host machine to save media natively.
# If omitted or commented out, Docker will temporarily default to the host's /tmp directory.
DOWNLOAD_DIR=/path/to/your/custom/folder

# File Ownership (Effective when storing files locally instead of Google Drive)
# Linux/macOS users: Set your exact user ID (PUID) and group ID (PGID).
# Find these by running `id -u` and `id -g` in your host terminal.
# The worker will automatically `chown` downloaded files to match these IDs, preventing them from being locked as `root`.
PUID=1000
PGID=1000

# ==========================================
# Advanced Application Settings
# ==========================================
# Optional: Global yt-dlp arguments applied to every internal download command.
# Extremely useful for defining Radiko Premium credentials, proxy servers, or download rate limiting.
# YT_DLP_ARGS="-N 10 --extractor-args rajiko:premium_user=USER;premium_pass=PASS"

# Standard IANA Timezone string for internal logging
TZ=Asia/Tokyo
