# ==========================================
# AWS Credentials & Connection
# ==========================================
# AWS Access Key & Secret are required for the Video worker to read/delete 
# messages from its dedicated SQS queue. Provisioned via Terraform.
AWS_ACCESS_KEY_ID=your_tver_worker_access_key
AWS_SECRET_ACCESS_KEY=your_tver_worker_secret_key
# The AWS region where your SQS queues and SNS topics reside (default: ap-northeast-1)
AWS_REGION=ap-northeast-1

# The absolute URL of the TVer/Video SQS queue created by Terraform
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/media-downloader-tver

# ==========================================
# Storage & Ownership
# ==========================================
# Host directory mapping for local storage. 
# Set this to a specific folder path on your host machine to save videos natively.
# If omitted or commented out, Docker will temporarily default to the host's /tmp directory.
DOWNLOAD_DIR=/path/to/your/custom/folder

# File Ownership
# Linux/macOS users: Set your exact user ID (PUID) and group ID (PGID).
# Find these by running `id -u` and `id -g` in your host terminal.
# The worker will automatically `chown` downloaded files to match these IDs, preventing them from being locked as `root`.
PUID=1000
PGID=1000

# ==========================================
# Advanced Application Settings
# ==========================================
# Optional: Global yt-dlp arguments applied to every internal download command.
# Useful for defining video proxies, resolution restrictions, or download rate limits.
# YT_DLP_ARGS="-N 10 -f 'bestvideo[height<=1080]+bestaudio/best'"

# If set to true, the worker will emit a '<filename>.ready' marker file inside
# /app/downloads after each download completes. Use this to trigger external
# post-processing hooks (e.g., move files, notify Plex).
# CREATE_READY_FILE=true

# Standard IANA Timezone string for internal logging
TZ=Asia/Tokyo
