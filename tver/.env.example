# AWS Credentials (Requires SQS Read/Delete permissions for TVer worker)
AWS_ACCESS_KEY_ID=your_tver_worker_access_key
AWS_SECRET_ACCESS_KEY=your_tver_worker_secret_key
AWS_REGION=ap-northeast-1

# SQS Queue URL for TVer
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/media-downloader-tver

# Download Storage Configuration
# Set this to save media to a specific folder on your host machine.
# If left blank or commented out, downloads default to the host's /tmp directory.
DOWNLOAD_DIR=/path/to/your/custom/folder

# Application Settings
TZ=Asia/Tokyo
