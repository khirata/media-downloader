AWS_REGION=ap-northeast-1

# Radiko SQS
RADIKO_AWS_ACCESS_KEY_ID=your_radiko_worker_access_key
RADIKO_AWS_SECRET_ACCESS_KEY=your_radiko_worker_secret_key
RADIKO_SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/media-downloader-radiko

# Google Drive Configuration (Folder ID from URL)
# Leave this blank if you prefer to save files locally to your host's /tmp directory!
GDRIVE_FOLDER_ID=1ABCDEFG_Your_Folder_ID_Here

# Optional: Global yt-dlp arguments
# YT_DLP_ARGS="-N 10 --extractor-args rajiko:premium_user=USER;premium_pass=PASS"

# TVer SQS
TVER_AWS_ACCESS_KEY_ID=your_tver_worker_access_key
TVER_AWS_SECRET_ACCESS_KEY=your_tver_worker_secret_key
TVER_SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789012/media-downloader-tver

# Application Settings
TZ=Asia/Tokyo
